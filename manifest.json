{
  "manifest_version": 3,
  "name": "UT Registration SpeedRunner",
  "version": "1.2.0",
  "description": "Register faster. Secure your ideal schedule.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Registration SpeedRunner",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://utdirect.utexas.edu/*",
        "https://registrar.utexas.edu/*",
        "https://saifsyed08.github.io/ut-registration-speedrunner/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://utdirect.utexas.edu/*",
    "https://registrar.utexas.edu/*",
    "https://saifsyed08.github.io/ut-registration-speedrunner/*"
  ]
}
